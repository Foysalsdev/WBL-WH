# ═══════════════════════════════════════════════════════════════
#  WBL-WH · Environment Variables (TEMPLATE)
#  Copy this file to `.env` and fill in real values.
#  NEVER commit the real .env file to git.
# ═══════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────
# Local dev (SQLite)
DATABASE_URL="file:./db/custom.db"

# Production (Supabase PostgreSQL)
# Format: postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_URL="postgresql://postgres.abcdefghijklmnopqrstuvwxyz:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# ── Auth / Session ─────────────────────────────────────────────
# Used for signing session tokens (HMAC-SHA256).
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Public app URL (no trailing slash)
# Local:    http://localhost:3000
# Cloudflare: https://wbl-wh.pages.dev
NEXTAUTH_URL="http://localhost:3000"

# ── App Config ─────────────────────────────────────────────────
NODE_ENV="development"

# ── Optional: Error Monitoring (Sentry) ────────────────────────
# Sign up at https://sentry.io → create Next.js project → copy DSN
# SENTRY_DSN="https://your-key@sentry.io/project-id"

# ── Optional: Uptime Monitoring (Better Stack) ─────────────────
# Used by external uptime monitors — no code change needed
# Just set up monitor pointing to: https://your-domain/api/health

# ═══════════════════════════════════════════════════════════════
#  SECURITY NOTES
# ═══════════════════════════════════════════════════════════════
# 1. NEVER commit .env to git (it's in .gitignore)
# 2. NEVER share secrets in chat/email
# 3. Rotate NEXTAUTH_SECRET periodically (forces re-login for all users)
# 4. Use strong DB passwords (16+ chars, mixed case + symbols)
# 5. In Cloudflare, mark all secrets as "Encrypted"
# 6. Limit Supabase DB access to specific IPs if possible
