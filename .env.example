# ─────────────────────────────────────────────────────────────
#  WBL-WH · Environment Variables (TEMPLATE)
#  Copy this file to `.env` and fill in real values.
#  NEVER commit the real .env file to git.
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL) ────────────────────────────
# Local dev (SQLite) — used when running `bun run dev`
DATABASE_URL="file:./db/custom.db"

# Production (Supabase) — replace with your real connection string
# Format: postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_URL="postgresql://postgres.abcdefghijklmnopqrstuvwxyz:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# ── Auth ──────────────────────────────────────────────────────
# Used by NextAuth / JWT signing. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Public app URL (no trailing slash)
# Local:   http://localhost:3000
# Cloudflare: https://your-project.pages.dev
NEXTAUTH_URL="http://localhost:3000"

# ── Optional: Supabase anon key (only if using Supabase Auth/Storage) ──
# NEXT_PUBLIC_SUPABASE_URL="https://abcdefghijklmnop.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6..."
