// Whirlpool Bangladesh — WMS (better-edition)
// Next.js 16 + Prisma + shadcn/ui
// Supports both SQLite (local dev) and PostgreSQL (Supabase production).
// Set DATABASE_URL in .env to switch:
//   - Local:    file:./db/custom.db           → provider = sqlite
//   - Supabase: postgresql://postgres.[ref]... → provider = postgresql
// The schema is 100% PostgreSQL-compatible (no SQLite-specific types).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────
//  People
// ───────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String
  passwordHash          String?
  role                  String    @default("staff") // admin | manager | staff | viewer
  avatar                String?
  active                Boolean   @default(true)
  // Audit fields for security
  passwordChangedAt     DateTime?
  lastLoginAt           DateTime?
  failedLoginAttempts   Int       @default(0)
  lockedUntil           DateTime?
  // Soft delete
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([active])
  @@index([deletedAt])
}

model Customer {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  createdAt DateTime @default(now())
  orders    SalesOrder[]
}

model Supplier {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  createdAt DateTime @default(now())
  orders    PurchaseOrder[]
}

// ───────────────────────────────────────────────
//  Catalog & locations
// ───────────────────────────────────────────────

model Product {
  id           String    @id @default(cuid())
  sku          String    @unique
  name         String
  category     String?
  description  String?
  unit         String    @default("pcs")
  barcode      String?
  costPrice    Float     @default(0)
  salePrice    Float     @default(0)
  reorderLevel Int       @default(10)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  stock     Stock?
  movements Movement[]
  poItems   PurchaseOrderItem[]
  soItems   SalesOrderItem[]
  dispatchItems DispatchItem[]

  @@index([isActive])
  @@index([deletedAt])
  @@index([category])
}

model Warehouse {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  address   String?
  city      String?
  capacity  Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  locations Location[]

  @@index([deletedAt])
}

model Location {
  id          String   @id @default(cuid())
  warehouseId String
  zone        String
  rack        String
  bin         String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  createdAt   DateTime @default(now())
}

// ───────────────────────────────────────────────
//  Inventory
// ───────────────────────────────────────────────

model Stock {
  id          String   @id @default(cuid())
  productId   String   @unique
  quantity    Int      @default(0)
  reserved    Int      @default(0)
  damaged     Int      @default(0)
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id])
}

model Movement {
  id         String   @id @default(cuid())
  productId  String
  type       String   // IN | OUT | ADJUST | TRANSFER
  quantity   Int      // signed (+/-)
  reference  String?
  notes      String?
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id])
}

// ───────────────────────────────────────────────
//  Procurement (Inbound)
// ───────────────────────────────────────────────

model PurchaseOrder {
  id              String   @id @default(cuid())
  poNumber        String   @unique
  supplierId      String
  status          String   @default("draft") // draft | ordered | partial | received | cancelled
  totalAmount     Float    @default(0)
  orderDate       DateTime @default(now())
  expectedDate    DateTime?
  receivedDate    DateTime?
  receivedBy      String?
  grnNumber       String?
  vehicleNo       String?  // supplier delivery vehicle
  invoiceRef      String?  // supplier invoice/challan reference
  notes           String?
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  items           PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  poId            String
  productId       String
  quantity        Int     // ordered
  receivedQty     Int     @default(0) // total received so far
  passedQty       Int     @default(0) // quality-checked OK
  failedQty       Int     @default(0) // damaged / rejected on receipt
  unitPrice       Float
  putawayLocation String? // zone/rack/bin where stock was put away
  po              PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])
}

// ───────────────────────────────────────────────
//  Sales (Outbound)
// ───────────────────────────────────────────────

model SalesOrder {
  id              String   @id @default(cuid())
  soNumber        String   @unique
  customerId      String
  // Workflow: draft → confirmed → picked → scanned → ready → partially_dispatched → dispatched → delivered | cancelled
  status          String   @default("draft")
  totalAmount     Float    @default(0)
  orderDate       DateTime @default(now())
  deliveryDate    DateTime?
  notes           String?
  // Step 1: Pick
  pickedBy        String?
  pickedAt        DateTime?
  // Step 2: Scan (barcode verification)
  scannedBy       String?
  scannedAt       DateTime?
  // Step 3: Invoice
  sapInvoiceRef    String?  // SAP invoice reference (entered manually, not generated)
  sapInvoiceDate DateTime?
  readyBy         String?  // who marked ready for dispatch
  cartonCount     Int      @default(0)
  // Steps 4 & 5 are now tracked per-dispatch (see Dispatch model)
  customer        Customer @relation(fields: [customerId], references: [id])
  items           SalesOrderItem[]
  dispatches      Dispatch[]
}

model SalesOrderItem {
  id            String  @id @default(cuid())
  soId          String
  productId     String
  quantity      Int     // ordered
  pickedQty     Int     @default(0) // picked from shelf
  scannedQty    Int     @default(0) // barcode-verified
  deliveredQty  Int     @default(0) // total delivered across all dispatches
  unitPrice     Float
  so            SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id])
}

// ───────────────────────────────────────────────
//  Dispatch (partial delivery tracking)
//  One invoice can have multiple dispatches.
//  Each dispatch is either Transport (own vehicle) or Courier (3rd party).
//  Each dispatch has its own POD.
// ───────────────────────────────────────────────

model Dispatch {
  id              String   @id @default(cuid())
  soId            String
  dispatchNo      String   @unique  // DSP-2026-00001
  deliveryMethod  String   // transport | courier
  // Transport fields (when deliveryMethod = transport)
  vehicleNo       String?
  driverName      String?
  driverPhone     String?
  // Courier fields (when deliveryMethod = courier)
  courierName     String?  // Steadfast, Pathao, REDX, etc.
  trackingNumber  String?  // courier tracking ID
  // Common
  challanNo       String?
  dispatchedAt    DateTime @default(now())
  dispatchedBy    String?
  notes           String?
  totalQty        Int      @default(0) // total units in this dispatch
  totalAmount     Float    @default(0) // value of goods in this dispatch
  // POD (proof of delivery) — per dispatch
  podStatus       String   @default("pending") // pending | confirmed | failed | rescheduled
  podReceivedBy   String?
  podDate         DateTime?
  podNotes        String?
  // Relations
  so              SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  items           DispatchItem[]
}

model DispatchItem {
  id          String  @id @default(cuid())
  dispatchId  String
  soItemId    String
  productId   String
  quantity    Int     // quantity delivered in THIS dispatch
  unitPrice   Float
  dispatch    Dispatch @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
}

// ───────────────────────────────────────────────
//  Transport Vendor (owns vehicles + drivers)
// ───────────────────────────────────────────────

model TransportVendor {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  phone     String?
  address   String?
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  vehicles  Vehicle[]

  @@index([active])
  @@index([deletedAt])
}

model Vehicle {
  id               String   @id @default(cuid())
  vehicleNo        String   @unique  // e.g. "DM TA 12-1212"
  transportVendorId String
  driverName       String?
  driverPhone      String?
  transportVendor  TransportVendor @relation(fields: [transportVendorId], references: [id])
  createdAt        DateTime @default(now())
}

// ───────────────────────────────────────────────
//  Courier Vendor (3rd party delivery)
// ───────────────────────────────────────────────

model CourierVendor {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  phone     String?
  address   String?
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([active])
  @@index([deletedAt])
}

// ───────────────────────────────────────────────
//  Returns / Exchanges / Replacements
//  Customer returns an item (damaged/wrong/unsatisfied)
//  → Choose: refund, exchange for another product, or replacement
// ───────────────────────────────────────────────

model Return {
  id              String   @id @default(cuid())
  returnNo        String   @unique  // RTN-2026-00001
  date            DateTime @default(now())
  soId            String?  // linked Sales Order (if from a sale)
  dispatchId      String?  // linked Dispatch (if specific trip)
  customerId      String
  reason          String   // damaged | wrong_item | warranty | unsatisfied | other
  reasonDetails   String?
  returnType      String   // refund | exchange | replacement
  status          String   @default("pending") // pending | processed | rejected
  processedBy     String?
  processedAt     DateTime?
  refundAmount    Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           ReturnItem[]

  @@index([customerId])
  @@index([soId])
  @@index([status])
  @@index([date])
}

model ReturnItem {
  id              String   @id @default(cuid())
  returnId        String
  productId       String   // product being returned
  quantity        Int      // qty returned
  condition       String   @default("good") // good | damaged | defective
  // For exchange: which product is being given in exchange
  exchangeProductId String?
  exchangeQuantity  Int    @default(0)
  // For refund: how much to refund per unit
  refundPerUnit   Float    @default(0)
  return          Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([productId])
}

// ───────────────────────────────────────────────
//  Order Timeline — every status change tracked
//  Gives a complete history of any order (PO/SO/Dispatch)
// ───────────────────────────────────────────────

model OrderTimeline {
  id          String   @id @default(cuid())
  entityType  String   // PurchaseOrder | SalesOrder | Dispatch | Return
  entityId    String
  fromStatus  String?
  toStatus    String
  action      String   // status_change | create | update | pick | scan | invoice | dispatch | receive | pod
  userName    String?
  notes       String?
  metadata    String?  // JSON string with extra context
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([entityType, createdAt])
}

// ───────────────────────────────────────────────
//  Audit trail
// ───────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // CREATE | UPDATE | DELETE | POST | CONFIRM | ADJUST
  entity    String
  entityId  String?
  userName  String?
  details   String?
  createdAt DateTime @default(now())
}

// ───────────────────────────────────────────────
//  RBAC — Role-Based Access Control
//  Admin creates roles, assigns permissions, sets user roles.
//  Permissions are module.action pairs (e.g. "inventory.view", "inbound.create")
// ───────────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String   @unique  // admin | manager | staff | viewer
  label       String            // display name: "Administrator", "Warehouse Manager"
  description String?
  isSystem    Boolean  @default(false) // system roles can't be deleted
  createdAt   DateTime @default(now())
  permissions Permission[]
}

model Permission {
  id          String   @id @default(cuid())
  roleId      String
  module      String   // dashboard | inventory | masters | inbound | outbound | reports | audit | users
  action      String   // view | create | edit | delete | print | post
  roleId_rel  Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
}
